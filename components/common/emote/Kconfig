menu "Emote"

    config EMOTE_RGB888_SUPPORT
        bool "Enable RGB888 LCD flush conversion"
        depends on ESP_BOARD_DEV_DISPLAY_LCD_SUPPORT
        default n
        help
            Enable RGB565-to-RGB888 conversion in the emote flush path for 24-bit LCD panels.
            The emote renderer keeps RGB565 as its internal format and expands pixels before
            passing frame chunks to esp_lcd_panel_draw_bitmap().

endmenu
