CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# 8MB flash (per original config)
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_8MB.csv"

# Audio: internal/dummy codec over I2S (MAX98357 + INMP441)
CONFIG_CODEC_DUMMY_SUPPORT=y
CONFIG_ESP_BOARD_PERIPH_I2S_SUPPORT=y

# LCD: ST7789 240x240
CONFIG_LCD_ST7789_240X240_7PIN=y

# USB: Serial JTAG
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
